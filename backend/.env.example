# ==========================================
# StayMate Backend Environment Configuration
# ==========================================

# ------------------------------------------
# 1. SERVER CONFIGURATION
# ------------------------------------------
# Server listener port
PORT=5000

# Execution mode: 'development', 'production', or 'test'
NODE_ENV=development

# Client URL (for CORS and email redirect links)
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Server URL (for socket configurations and self references)
SERVER_URL=http://localhost:5000

# ------------------------------------------
# 2. DATABASE CONFIGURATION
# ------------------------------------------
# Connection string to MongoDB (Local or MongoDB Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/staymate

# ------------------------------------------
# 3. SECURITY & CRYPTO SECRETS
# ------------------------------------------
# Key for signing Access JSON Web Tokens
JWT_SECRET=staymate_secret_key_12345

# Key for signing Refresh JSON Web Tokens (session rotation)
JWT_REFRESH_SECRET=staymate_refresh_key_12345

# Cookie encryption password for HttpOnly refresh session tracking
COOKIE_SECRET=staymate_cookie_secret_key_12345

# Access token duration (e.g. '15m', '1h')
ACCESS_TOKEN_EXPIRY=15m

# Refresh token duration (e.g. '7d', '30d')
REFRESH_TOKEN_EXPIRY=7d

# ------------------------------------------
# 4. GOOGLE OAUTH SECURITY
# ------------------------------------------
# Credentials obtained from Google Cloud APIs & Services credentials dashboard
GOOGLE_CLIENT_ID=google_client_id_placeholder_value
GOOGLE_CLIENT_SECRET=google_client_secret_placeholder_value

# ------------------------------------------
# 5. CLOUDINARY FILE STORAGE
# ------------------------------------------
# Credentials obtained from your Cloudinary API console dashboard settings.
# - Fallback: If omitted, uploads default to local storage in public/uploads directory.
CLOUDINARY_NAME=cloudinary_name_placeholder_value
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_SECRET=cloudinary_secret_placeholder_value

# ------------------------------------------
# 6. RAZORPAY PAYMENT GATEWAY
# ------------------------------------------
# Credentials obtained from the Razorpay API Dashboard (API Keys panel).
# - Fallback: If omitted, StayMate operates in offline mock transaction mode.
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ------------------------------------------
# 7. EMAIL SERVICE (SMTP)
# ------------------------------------------
# Settings for sending actual transactional emails (verifications, password resets).
# - If omitted, emails default to logging to the server console.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username_here
SMTP_PASS=your_smtp_app_password_here
EMAIL_FROM=no-reply@staymate.com
EMAIL_FROM_NAME=StayMate


