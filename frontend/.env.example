# ==========================================
# StayMate Frontend Environment Configuration
# ==========================================

# ------------------------------------------
# 1. API & SOCKET CONNECTIONS
# ------------------------------------------
# The base URL of the REST API (used by Axios client instance)
VITE_API_URL=http://localhost:5000/api/v1

# The backend root URL (used for Socket.io client connection and report endpoints)
VITE_BACKEND_URL=http://localhost:5000

# ------------------------------------------
# 2. GOOGLE MAPS PLATFORM
# ------------------------------------------
# Your Google Maps JavaScript SDK API Key.
# - Required APIs to enable on Google Cloud Console: 
#   - Maps JavaScript API
#   - Places API
#   - Geocoding API
# - Security recommendations: Restrict API Key usage by HTTP Referrer under credentials settings.
# - Fallback: If omitted or invalid, StayMate operates in offline SVG map emulation mode.
VITE_GOOGLE_MAPS_KEY=your_google_maps_key_here

# ------------------------------------------
# 3. GOOGLE AUTHENTICATION
# ------------------------------------------
# Google Client ID for OAuth login button setup.
# - Can be obtained from the Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client IDs.
# - Add authorized javascript origin: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=google_client_id_placeholder_value


